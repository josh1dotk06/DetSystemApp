<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.example.detsystem.HomeBackgroundView
        android:id="@+id/homeBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:id="@+id/appTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DET SYSTEM"
            android:textColor="#E7C6FF"
            android:textSize="42sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:shadowColor="#B026FF"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="18" />

        <TextView
            android:id="@+id/appSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Challenge yourself. Stay accountable."
            android:textColor="#BDBDBD"
            android:textSize="16sp"
            android:gravity="center"
            android:shadowColor="#7B2CBF"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="8" />

        <Button
            android:id="@+id/signupButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="56dp"
            android:background="@drawable/neon_button"
            android:text="CREATE ACCOUNT"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="15sp" />

        <Button
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/neon_button"
            android:text="LOG IN"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="15sp" />

    </LinearLayout>

</FrameLayout>