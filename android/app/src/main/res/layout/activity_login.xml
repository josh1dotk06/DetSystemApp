<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.example.detsystem.HomeBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOG IN"
            android:textColor="#E7C6FF"
            android:textSize="38sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:shadowColor="#B026FF"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="18" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter the Det System"
            android:textColor="#BDBDBD"
            android:textSize="16sp"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/loginEmailInput"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/neon_input"
            android:hint="Email or username"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:singleLine="true"
            android:inputType="textEmailAddress" />

        <EditText
            android:id="@+id/loginPasswordInput"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/neon_input"
            android:hint="Password"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:singleLine="true"
            android:inputType="textPassword" />

        <Button
            android:id="@+id/loginSubmitButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/neon_button"
            android:text="LOG IN"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="15sp" />

        <Button
            android:id="@+id/backFromLoginButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/neon_button"
            android:text="BACK"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>